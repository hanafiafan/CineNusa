# ══════════════════════════════════════════════════════════════════
# CineNusa — Environment Variables
# Salin file ini → .env, lalu isi nilainya.
# JANGAN commit .env ke GitHub (sudah ada di .gitignore).
# ══════════════════════════════════════════════════════════════════

# Flask
FLASK_SECRET_KEY=ganti-dengan-string-acak-yang-panjang
FLASK_ENV=development

# Supabase (https://supabase.com/dashboard → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# TMDB Poster Fetcher (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# Optional: ubah port default (5000)
# PORT=5000
